{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true, // 🚨 REQUIRED for project references
    "declaration": true, // 🚨 REQUIRED when composite is true
    "declarationMap": true, // (Optional but Senior) Lets you Ctrl+Click to see original TS code instead of types
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "references": [],
  "exclude": ["jest.config.ts", "jest.config.cts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
