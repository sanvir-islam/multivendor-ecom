{
  "name": "@multivendor-ecom/api-gateway",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/dist/apps/api-gateway/package.json",
          "{workspaceRoot}/dist/apps/api-gateway/package-lock.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/dist/apps/api-gateway/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@multivendor-ecom/api-gateway:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@multivendor-ecom/api-gateway:build:development"
          },
          "production": {
            "buildTarget": "@multivendor-ecom/api-gateway:build:production"
          }
        }
      }
    }
  },
  "dependencies": {
    "@multivendor-ecom/shared": "workspace:*",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express-http-proxy": "^2.1.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express-http-proxy": "^1.6.7",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10"
  }
}
