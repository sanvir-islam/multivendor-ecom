{
  "compilerOptions": {
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@multivendor-ecom/shared": ["packages/shared/src/index.ts"],
      "@multivendor-ecom/shared/*": ["packages/shared/src/*"]
    }
  }
}
